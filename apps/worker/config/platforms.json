{
  "tencent": {
    "joinUrlTemplate": "https://meeting.tencent.com/wc/{meetingId}",
    "browser": {
      "windowWidth": 1280,
      "windowHeight": 720
    },
    "selectors": {
      "browserEntryButton": "text=/浏览器入会|继续使用浏览器/i",
      "displayNameInput": "input[placeholder*='昵称'], input[placeholder*='姓名']",
      "meetingPasswordInput": "input[type='password']",
      "joinButton": "button:has-text('加入会议'), button:has-text('入会')",
      "muteButton": "[aria-label*='静音'], button:has-text('静音')",
      "cameraButton": "[aria-label*='摄像头'], button:has-text('摄像头')",
      "participantCount": "[data-testid='participants-count'], .participant-count",
      "meetingEndedBanner": "text=/会议已结束|会议结束|已离开会议/i",
      "leaveButton": "button:has-text('离开会议')"
    }
  },
  "dingtalk": {
